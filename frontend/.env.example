# Production (set in Vercel → Environment Variables, then redeploy)
# Railway API URL — include /api at the end
VITE_API_URL=https://YOUR-BACKEND.up.railway.app/api
# Socket.IO host — same backend, no /api path
VITE_SOCKET_URL=https://YOUR-BACKEND.up.railway.app
# Copied share links use this origin
VITE_PUBLIC_APP_URL=https://YOUR-APP.vercel.app

# Local dev only (Vite proxy — see vite.config.js)
# VITE_API_PROXY_TARGET=http://localhost:4000
