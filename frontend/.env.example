# Optional: API base URL when not using Vite proxy (production build)
# VITE_API_URL=https://your-api.example.com/api

# Optional: public site origin for copied share links
# VITE_PUBLIC_APP_URL=https://your-app.example.com

# Optional: Socket.IO server origin if different from the page
# VITE_SOCKET_URL=https://your-api.example.com

# Dev only: backend URL for Vite proxy (see vite.config.js)
# VITE_API_PROXY_TARGET=http://localhost:4000
